# Database Configuration
DB_HOST=
DB_USER=
DB_PASSWORD=

# Redis Configuration
REDIS_HOST=
REDIS_PORT=6379

# MinIO Configuration
MINIO_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Ollama Configuration
OLLAMA_URL=
# How long models stay loaded after a request (avoids reload spikes)
OLLAMA_KEEP_ALIVE=30m
# Max CPU threads per inference request (keeps the Ollama host responsive)
OLLAMA_NUM_THREAD=8

# Frontend Configuration
FRONTEND_URL=

# JWT signing secret — REQUIRED. Generate with: openssl rand -hex 32
# Without it the app falls back to a publicly known default and admin tokens can be forged.
WEBUI_SECRET_KEY=
